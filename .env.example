# Sao chép thành .env và điền giá trị. Không commit .env.

# Backend RAG / API
VITE_API_BASE_URL=
VITE_RAG_UPLOAD_FIELD=file

# ── Vị thế Futures (testnet) ─────────────────────────────────────────────
# Chỉ dùng testnet. Key/secret được embed vào bundle — production nên dùng backend.
#
# Đặt MỘT trong hai bộ tên:
#   A) VITE_BINANCE_FUTURES_TESTNET_API_KEY + VITE_BINANCE_FUTURES_TESTNET_API_SECRET
#   B) VITE_BINANCE_FUTURES_API_KEY + VITE_BINANCE_FUTURES_API_SECRET
#
# Tuỳ chọn:
#   VITE_BINANCE_FUTURES_WS_URL          (mặc định: wss://testnet.binancefuture.com/ws-fapi/v1)
#   VITE_BINANCE_POSITION_SYMBOL         hoặc VITE_BINANCE_FUTURES_SYMBOL (vd: BTCUSDT)
#   VITE_BINANCE_POSITION_POLL_MS        hoặc VITE_BINANCE_FUTURES_POLL_MS (ms, REST fallback)

# VITE_BINANCE_FUTURES_TESTNET_API_KEY=
# VITE_BINANCE_FUTURES_TESTNET_API_SECRET=
VITE_BINANCE_FUTURES_API_KEY=
VITE_BINANCE_FUTURES_API_SECRET=
VITE_BINANCE_FUTURES_WS_URL=wss://testnet.binancefuture.com/ws-fapi/v1
VITE_BINANCE_FUTURES_SYMBOL=BTCUSDT
# VITE_BINANCE_POSITION_SYMBOL=BTCUSDT
# VITE_BINANCE_POSITION_POLL_MS=5000
